generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // ou "sqlite"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String    @id @default(uuid())
  nome      String
  // O Workspace é dono das colunas (Biblioteca Geral)
  colunas   Coluna[]  
  usuarios  Usuario[]
  projetos  Projeto[]
  dt_insert DateTime  @default(now())
}

model Usuario {
  id           String       @id @default(uuid())
  nome         String
  email        String       @unique
  senha        String       // Obrigatório para Login
  role         String       @default("USER") // OWNER, ADMIN, USER
  ativo        Boolean      @default(true)
  imagem       String?
  cargo        String?
  
  workspace_id String
  workspace    Workspace    @relation(fields: [workspace_id], references: [id])
  
  projetos     Projeto[]    // Projetos que criou
  tarefas      Tarefa[]
  comentarios  Comentario[]
  acoes_historico HistoricoTarefa[]
  dt_insert    DateTime     @default(now())
  dt_update   DateTime @updatedAt @default(now())
}

model Coluna {
  id           String          @id @default(uuid())
  nome         String          // Ex: "Backlog"
  cor          String?         // Ex: "bg-gray-200"
  
  // Pertence ao Workspace (Biblioteca Global)
  workspace_id String
  workspace    Workspace       @relation(fields: [workspace_id], references: [id])
  
  // Usada em vários projetos (Relação N:N)
  projetos     ProjetoColuna[] 
  
  // Tarefas que estão nessa coluna
  tarefas      Tarefa[]        
  
  dt_insert    DateTime        @default(now())
  dt_update   DateTime @updatedAt @default(now())
}

model Projeto {
  id           String    @id @default(uuid())
  nome         String
  descricao    String?   @db.Text

  ativo          Boolean   @default(true)
  
  workspace_id String
  workspace    Workspace @relation(fields: [workspace_id], references: [id])
  
  usuario_id   String    // Dono
  usuario      Usuario   @relation(fields: [usuario_id], references: [id])

  // Ligações
  colunas      ProjetoColuna[]
  tarefas      Tarefa[]
  
  dt_insert    DateTime  @default(now())
  dt_update   DateTime @updatedAt @default(now())
  dt_acesso    DateTime  @default(now())
}

// TABELA PIVÔ: Define a ordem das colunas DENTRO de um projeto específico
model ProjetoColuna {
  projeto_id String
  projeto    Projeto @relation(fields: [projeto_id], references: [id], onDelete: Cascade)
  coluna_id  String
  coluna     Coluna  @relation(fields: [coluna_id], references: [id], onDelete: Cascade)
  ordem      Int     // 1, 2, 3...
  
  @@id([projeto_id, coluna_id])
}

enum Recorrencia {
  NAO
  DIARIAMENTE
  SEMANALMENTE
  MENSALMENTE
}

model Tarefa {
  id            String    @id @default(cuid())
  titulo        String
  descricao     String?
  concluida     Boolean   @default(false)
  dt_vencimento DateTime?
  dt_conclusao  DateTime?
  dt_insert     DateTime  @default(now())
  dt_update   DateTime @updatedAt @default(now())

  prioridade_id Int
  prioridade    OpcaoPrioridade @relation(fields: [prioridade_id], references: [id])

  dificuldade_id Int
  dificuldade    OpcaoDificuldade @relation(fields: [dificuldade_id], references: [id])

  projeto_id    String
  projeto       Projeto   @relation(fields: [projeto_id], references: [id], onDelete: Cascade)

  coluna_id     String?
  coluna        Coluna?   @relation(fields: [coluna_id], references: [id])

  usuario_id    String?
  usuario       Usuario?  @relation(fields: [usuario_id], references: [id])

  comentarios   Comentario[]
  historico       HistoricoTarefa[]

  recorrencia       Recorrencia @default(NAO)

  anexos         Anexo[]
}

// --- NOVAS TABELAS AUXILIARES ---

model OpcaoPrioridade {
  id      Int      @id // Vamos usar 1, 2, 3 manualmente
  nome    String   // "Baixa", "Média", "Alta"
  tarefas Tarefa[]
}

model OpcaoDificuldade {
  id      Int      @id // Vamos usar 1, 2, 3, 4, 5
  nome    String   // "Muito Fácil", "Fácil", etc
  tarefas Tarefa[]
}

model Comentario {
  id         String   @id @default(uuid())
  texto      String   @db.Text
  tarefa_id  String
  tarefa     Tarefa   @relation(fields: [tarefa_id], references: [id], onDelete: Cascade)
  usuario_id String
  usuario    Usuario  @relation(fields: [usuario_id], references: [id])
  dt_insert  DateTime @default(now())
  dt_update   DateTime @updatedAt @default(now())
}

// --- NOVO: ENUM PARA TIPOS DE ALTERAÇÃO ---
enum CampoAlterado {
  CRIACAO
  TITULO
  DESCRICAO
  DT_VENCIMENTO
  PRIORIDADE
  DIFICULDADE
  COLUNA
  CONCLUSAO
  REABERTURA
  RESPONSAVEL
  ANEXO_REMOVIDO
}

// --- NOVO: TABELA DE HISTÓRICO (LOG) ---
model HistoricoTarefa {
  id          String   @id @default(uuid())
  
  tarefa_id   String
  tarefa      Tarefa   @relation(fields: [tarefa_id], references: [id], onDelete: Cascade)

  usuario_id  String?  // Quem fez a alteração
  usuario     Usuario? @relation(fields: [usuario_id], references: [id])

  campo       CampoAlterado // O que mudou? (Ex: DT_VENCIMENTO)
  
  valor_antigo String?  // Ex: "2026-02-01"
  valor_novo   String?  // Ex: "2026-02-10"

  dt_evento    DateTime @default(now())

  // Índice para deixar os relatórios rápidos
  @@index([tarefa_id])
  @@index([dt_evento])
}

model Anexo {
  id          String   @id @default(uuid())
  nome        String   // Nome do arquivo (ex: contrato.pdf)
  url         String   // O link do UploadThing
  key         String   // ID único do arquivo no storage
  tamanho     Int      // Tamanho em bytes
  
  dt_upload   DateTime @default(now())

  tarefa_id   String
  tarefa      Tarefa   @relation(fields: [tarefa_id], references: [id], onDelete: Cascade)
}