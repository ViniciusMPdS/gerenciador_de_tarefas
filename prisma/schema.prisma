generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String    @id @default(uuid())
  nome      String
  dt_insert DateTime  @default(now())
  
  equipes   Equipe[]
  colunas   Coluna[]
  projetos  Projeto[]
  usuarios  Usuario[]

  @@map("workspace")
}

// ==========================================
// TABELAS DE EQUIPE
// ==========================================

model Equipe {
  id           String          @id @default(uuid())
  nome         String
  descricao    String?
  workspace_id String
  dt_insert    DateTime        @default(now())
  dt_update    DateTime        @default(now()) @updatedAt

  workspace    Workspace       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  membros      EquipeUsuario[]
  projetos     Projeto[]
  colunas      Coluna[]
  pacotes      PacoteTemplate[] // Nova ligação: Cada equipe tem seus pacotes

  @@map("equipe")
}

model EquipeUsuario {
  equipe_id  String
  usuario_id String
  role       String   @default("MEMBER")
  dt_insert  DateTime @default(now())

  equipe     Equipe   @relation(fields: [equipe_id], references: [id], onDelete: Cascade)
  usuario    Usuario  @relation(fields: [usuario_id], references: [id], onDelete: Cascade)

  @@id([equipe_id, usuario_id])
  @@map("equipe_usuario")
}

// ==========================================
// TABELAS ATUALIZADAS
// ==========================================

model Usuario {
  id              String            @id @default(uuid())
  nome            String
  email           String            @unique
  senha           String
  dt_insert       DateTime          @default(now())
  ativo           Boolean           @default(true)
  cargo           String?
  dt_update       DateTime          @default(now()) @updatedAt
  imagem          String?
  role            String            @default("USER")
  workspace_id    String
  
  equipes         EquipeUsuario[]
  comentarios     Comentario[]
  acoes_historico HistoricoTarefa[]
  projetos        Projeto[]
  tarefas         Tarefa[]
  workspace       Workspace         @relation(fields: [workspace_id], references: [id], map: "Usuario_workspace_id_fkey")

  @@map("usuario")
}

model Coluna {
  id           String          @id(map: "Coluna_pkey") @default(uuid())
  nome         String
  cor          String?
  workspace_id String
  dt_insert    DateTime        @default(now())
  dt_update    DateTime        @default(now()) @updatedAt
  equipe_id    String?
  
  equipe       Equipe?         @relation(fields: [equipe_id], references: [id], onDelete: SetNull)
  workspace    Workspace       @relation(fields: [workspace_id], references: [id], map: "Coluna_workspace_id_fkey")
  projetos     ProjetoColuna[]
  tarefas      Tarefa[]

  @@map("coluna")
}

model Projeto {
  id             String          @id @default(uuid())
  nome           String
  workspace_id   String
  dt_insert      DateTime        @default(now())
  descricao      String?
  dt_acesso      DateTime        @default(now())
  dt_update      DateTime        @default(now()) @updatedAt
  usuario_id     String
  ativo          Boolean         @default(true)
  imagem         String?
  equipe_id      String?
  
  // --- NOVOS CAMPOS PARA O PORTFÓLIO MACRO (ONBLOX) ---
  fase_macro     String?         // Ex: "Modelagem", "Go Live"
  erp            String?         // Ex: "Winthor", "Sankhya"
  dados_acesso   String?         // Ex: "TeamViewer: 123 456 | Senha: abc"
  status_cliente String?         @default("EM_ANDAMENTO") // Ex: "EM_ANDAMENTO", "PAUSADO", "CONCLUIDO"
  pacote_onblox   String?         // Ex: "WMS + REMOTO"
  tipo_integracao String?         // Ex: "VIEW", "API", "BANCO DE DADOS"
  motivo_pausa    String?         // Se o status for PAUSADO
  // --------------------------------------------------

  equipe         Equipe?         @relation(fields: [equipe_id], references: [id], onDelete: SetNull)
  usuario        Usuario         @relation(fields: [usuario_id], references: [id], map: "Projeto_usuario_id_fkey")
  workspace      Workspace       @relation(fields: [workspace_id], references: [id], map: "Projeto_workspace_id_fkey")
  colunas        ProjetoColuna[]
  tarefas        Tarefa[]

  @@map("projeto")
}

// ==========================================
// TABELAS MANTIDAS INTACTAS
// ==========================================

model ProjetoColuna {
  projeto_id String
  coluna_id  String
  ordem      Int
  coluna     Coluna  @relation(fields: [coluna_id], references: [id], onDelete: Cascade, map: "ProjetoColuna_coluna_id_fkey")
  projeto    Projeto @relation(fields: [projeto_id], references: [id], onDelete: Cascade, map: "ProjetoColuna_projeto_id_fkey")

  @@id([projeto_id, coluna_id])
  @@map("projeto_coluna")
}

model Tarefa {
  id             String            @id @default(uuid())
  titulo         String
  descricao      String?
  usuario_id     String?
  dt_insert      DateTime          @default(now())
  coluna_id      String?
  concluida      Boolean           @default(false)
  dificuldade_id Int
  dt_conclusao   DateTime?
  dt_update      DateTime          @default(now()) @updatedAt
  dt_vencimento  DateTime?
  prioridade_id  Int
  projeto_id     String
  recorrencia    Recorrencia       @default(NAO)
  anexos         Anexo[]
  comentarios    Comentario[]
  historico      HistoricoTarefa[]
  coluna         Coluna?           @relation(fields: [coluna_id], references: [id], map: "Tarefa_coluna_id_fkey")
  dificuldade    OpcaoDificuldade  @relation(fields: [dificuldade_id], references: [id], map: "Tarefa_dificuldade_id_fkey")
  prioridade     OpcaoPrioridade   @relation(fields: [prioridade_id], references: [id], map: "Tarefa_prioridade_id_fkey")
  projeto        Projeto           @relation(fields: [projeto_id], references: [id], onDelete: Cascade, map: "Tarefa_projeto_id_fkey")
  usuario        Usuario?          @relation(fields: [usuario_id], references: [id], map: "Tarefa_usuario_id_fkey")

  @@map("tarefa")
}

model OpcaoPrioridade {
  id      Int      @id(map: "OpcaoPrioridade_pkey")
  nome    String
  tarefas Tarefa[]

  @@map("opcao_prioridade")
}

model OpcaoDificuldade {
  id      Int      @id(map: "OpcaoDificuldade_pkey")
  nome    String
  tarefas Tarefa[]

  @@map("opcao_dificuldade")
}

model Comentario {
  id         String   @id(map: "Comentario_pkey") @default(uuid())
  texto      String
  tarefa_id  String
  usuario_id String
  dt_insert  DateTime @default(now())
  dt_update  DateTime @default(now()) @updatedAt
  imagemUrl  String?
  tarefa     Tarefa   @relation(fields: [tarefa_id], references: [id], onDelete: Cascade, map: "Comentario_tarefa_id_fkey")
  usuario    Usuario  @relation(fields: [usuario_id], references: [id], map: "Comentario_usuario_id_fkey")

  @@map("comentario")
}

model HistoricoTarefa {
  id           String        @id(map: "HistoricoTarefa_pkey") @default(uuid())
  tarefa_id    String
  usuario_id   String?
  campo        CampoAlterado
  valor_antigo String?
  valor_novo   String?
  dt_evento    DateTime      @default(now())
  tarefa       Tarefa        @relation(fields: [tarefa_id], references: [id], onDelete: Cascade, map: "HistoricoTarefa_tarefa_id_fkey")
  usuario      Usuario?      @relation(fields: [usuario_id], references: [id], map: "HistoricoTarefa_usuario_id_fkey")

  @@index([dt_evento])
  @@index([tarefa_id])
  @@map("historico_tarefa")
}

model Anexo {
  id        String   @id(map: "Anexo_pkey") @default(uuid())
  nome      String
  url       String
  key       String
  tamanho   Int
  dt_upload DateTime @default(now())
  tarefa_id String
  tarefa    Tarefa   @relation(fields: [tarefa_id], references: [id], onDelete: Cascade, map: "Anexo_tarefa_id_fkey")

  @@map("anexo")
}

// ==========================================
// NOVAS TABELAS DO MOTOR DE TEMPLATES
// ==========================================

model PacoteTemplate {
  id           String           @id @default(uuid())
  nome         String           // Ex: "Modelagem Macropack"
  descricao    String?          
  equipe_id    String
  dt_insert    DateTime         @default(now())
  dt_update    DateTime         @default(now()) @updatedAt

  equipe       Equipe           @relation(fields: [equipe_id], references: [id], onDelete: Cascade)
  tarefas      TarefaTemplate[]

  @@map("pacote_template")
}

model TarefaTemplate {
  id             String         @id @default(uuid())
  titulo         String         // Ex: "Validar Cadastros de Dicon"
  descricao      String?
  dificuldade_id Int            @default(1) // Já injeta a tarefa com dificuldade Fácil
  prioridade_id  Int            @default(1) // Já injeta a tarefa com prioridade Baixa
  pacote_id      String
  dt_insert      DateTime       @default(now())

  pacote         PacoteTemplate @relation(fields: [pacote_id], references: [id], onDelete: Cascade)

  @@map("tarefa_template")
}

enum Recorrencia {
  NAO
  DIARIAMENTE
  SEMANALMENTE
  MENSALMENTE
}

enum CampoAlterado {
  CRIACAO
  TITULO
  DESCRICAO
  DT_VENCIMENTO
  PRIORIDADE
  DIFICULDADE
  COLUNA
  CONCLUSAO
  REABERTURA
  RESPONSAVEL
  ANEXO_REMOVIDO
}