generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String    @id(map: "Workspace_pkey") @default(uuid())
  nome      String
  dt_insert DateTime  @default(now())
  colunas   Coluna[]
  projetos  Projeto[]
  usuarios  Usuario[]

  @@map("workspace")
}

model Usuario {
  id              String            @id(map: "Usuario_pkey") @default(uuid())
  nome            String
  email           String            @unique(map: "Usuario_email_key")
  senha           String
  role            String            @default("USER")
  ativo           Boolean           @default(true)
  imagem          String?
  cargo           String?
  workspace_id    String
  dt_insert       DateTime          @default(now())
  dt_update       DateTime          @default(now()) @updatedAt
  comentarios     Comentario[]
  acoes_historico HistoricoTarefa[]
  projetos        Projeto[]
  tarefas         Tarefa[]
  workspace       Workspace         @relation(fields: [workspace_id], references: [id], map: "Usuario_workspace_id_fkey")

  @@map("usuario")
}

model Coluna {
  id           String          @id @default(uuid())
  nome         String
  cor          String?
  workspace_id String
  dt_insert    DateTime        @default(now())
  dt_update    DateTime        @default(now()) @updatedAt
  workspace    Workspace       @relation(fields: [workspace_id], references: [id], map: "Coluna_workspace_id_fkey")
  projetos     ProjetoColuna[]
  tarefas      Tarefa[]

  @@map("coluna")
}

model Projeto {
  id           String          @id(map: "Projeto_pkey") @default(uuid())
  nome         String
  descricao    String?
  workspace_id String
  usuario_id   String
  dt_insert    DateTime        @default(now())
  dt_update    DateTime        @default(now()) @updatedAt
  dt_acesso    DateTime        @default(now())
  ativo        Boolean         @default(true)
  imagem       String?
  usuario      Usuario         @relation(fields: [usuario_id], references: [id], map: "Projeto_usuario_id_fkey")
  workspace    Workspace       @relation(fields: [workspace_id], references: [id], map: "Projeto_workspace_id_fkey")
  colunas      ProjetoColuna[]
  tarefas      Tarefa[]

  @@map("projeto")
}

model ProjetoColuna {
  projeto_id String
  coluna_id  String
  ordem      Int
  coluna     Coluna  @relation(fields: [coluna_id], references: [id], onDelete: Cascade, map: "ProjetoColuna_coluna_id_fkey")
  projeto    Projeto @relation(fields: [projeto_id], references: [id], onDelete: Cascade, map: "ProjetoColuna_projeto_id_fkey")

  @@id([projeto_id, coluna_id], map: "ProjetoColuna_pkey")
  @@map("projeto_coluna")
}

model Tarefa {
  id             String            @id(map: "Tarefa_pkey") @default(uuid())
  titulo         String
  descricao      String?
  concluida      Boolean           @default(false)
  dt_vencimento  DateTime?
  dt_conclusao   DateTime?
  dt_insert      DateTime          @default(now())
  dt_update      DateTime          @default(now()) @updatedAt
  prioridade_id  Int
  dificuldade_id Int
  projeto_id     String
  coluna_id      String?
  usuario_id     String?
  recorrencia    Recorrencia       @default(NAO)
  anexos         Anexo[]
  comentarios    Comentario[]
  historico      HistoricoTarefa[]
  coluna         Coluna?           @relation(fields: [coluna_id], references: [id], map: "Tarefa_coluna_id_fkey")
  dificuldade    OpcaoDificuldade  @relation(fields: [dificuldade_id], references: [id], map: "Tarefa_dificuldade_id_fkey")
  prioridade     OpcaoPrioridade   @relation(fields: [prioridade_id], references: [id], map: "Tarefa_prioridade_id_fkey")
  projeto        Projeto           @relation(fields: [projeto_id], references: [id], onDelete: Cascade, map: "Tarefa_projeto_id_fkey")
  usuario        Usuario?          @relation(fields: [usuario_id], references: [id], map: "Tarefa_usuario_id_fkey")

  @@map("tarefa")
}

model OpcaoPrioridade {
  id      Int      @id(map: "OpcaoPrioridade_pkey")
  nome    String
  tarefas Tarefa[]

  @@map("opcao_prioridade")
}

model OpcaoDificuldade {
  id      Int      @id(map: "OpcaoDificuldade_pkey")
  nome    String
  tarefas Tarefa[]

  @@map("opcao_dificuldade")
}

model Comentario {
  id         String   @id(map: "Comentario_pkey") @default(uuid())
  texto      String
  tarefa_id  String
  usuario_id String
  dt_insert  DateTime @default(now())
  dt_update  DateTime @default(now()) @updatedAt
  tarefa     Tarefa   @relation(fields: [tarefa_id], references: [id], onDelete: Cascade, map: "Comentario_tarefa_id_fkey")
  usuario    Usuario  @relation(fields: [usuario_id], references: [id], map: "Comentario_usuario_id_fkey")
  imagemUrl  String?

  @@map("comentario")
}

model HistoricoTarefa {
  id           String        @id(map: "HistoricoTarefa_pkey") @default(uuid())
  tarefa_id    String
  usuario_id   String?
  campo        CampoAlterado
  valor_antigo String?
  valor_novo   String?
  dt_evento    DateTime      @default(now())
  tarefa       Tarefa        @relation(fields: [tarefa_id], references: [id], onDelete: Cascade, map: "HistoricoTarefa_tarefa_id_fkey")
  usuario      Usuario?      @relation(fields: [usuario_id], references: [id], map: "HistoricoTarefa_usuario_id_fkey")

  @@index([dt_evento], map: "HistoricoTarefa_dt_evento_idx")
  @@index([tarefa_id], map: "HistoricoTarefa_tarefa_id_idx")
  @@map("historico_tarefa")
}

model Anexo {
  id        String   @id @default(uuid())
  nome      String
  url       String
  key       String
  tamanho   Int
  dt_upload DateTime @default(now())
  tarefa_id String
  tarefa    Tarefa   @relation(fields: [tarefa_id], references: [id], onDelete: Cascade, map: "Anexo_tarefa_id_fkey")

  @@map("anexo")
}

enum Recorrencia {
  NAO
  DIARIAMENTE
  SEMANALMENTE
  MENSALMENTE
}

enum CampoAlterado {
  CRIACAO
  TITULO
  DESCRICAO
  DT_VENCIMENTO
  PRIORIDADE
  DIFICULDADE
  COLUNA
  CONCLUSAO
  REABERTURA
  RESPONSAVEL
  ANEXO_REMOVIDO
}
