generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ... suas models (Usuario, Projeto, etc) continuam iguais abaixo ...
model Usuario {
  id      String   @id @default(uuid())
  email   String   @unique
  nome    String?
  senha   String
  dt_insert DateTime @default(now())
  
  // Relações
  membros MembroWorkspace[]
  tarefas Tarefa[]
}

model Workspace {
  id        String   @id @default(uuid())
  nome      String
  dt_insert  DateTime @default(now())

  membros   MembroWorkspace[]
  projetos  Projeto[]
}

model MembroWorkspace {
  id          String    @id @default(uuid())
  papel       String    @default("MEMBER") // ADMIN, MEMBER
  usuario_id   String
  workspace_id String
  
  usuario     Usuario   @relation(fields: [usuario_id], references: [id])
  workspace   Workspace @relation(fields: [workspace_id], references: [id])
}

model Projeto {
  id          String   @id @default(uuid())
  nome        String
  descricao   String?
  workspace_id String
  
  workspace   Workspace @relation(fields: [workspace_id], references: [id])
  tarefas     Tarefa[]
}

model Tarefa {
  id          String   @id @default(uuid())
  titulo      String
  status      String   @default("PENDENTE") // PENDENTE, FAZENDO, FEITO
  prioridade  String   @default("MEDIA")    // BAIXA, MEDIA, ALTA
  projetoId   String
  usuario_id   String?  // Pode ser nulo se ninguém pegou a tarefa ainda

  projeto     Projeto  @relation(fields: [projetoId], references: [id])
  usuario     Usuario? @relation(fields: [usuario_id], references: [id])
}