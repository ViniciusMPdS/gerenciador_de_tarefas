generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String    @id @default(uuid())
  nome      String
  colunas   Coluna[]
  usuarios  Usuario[]
  projetos  Projeto[]
  dt_insert DateTime  @default(now())

  @@map("workspace")
}

model Usuario {
  id              String            @id @default(uuid())
  nome            String
  email           String            @unique
  senha           String
  role            String            @default("USER")
  ativo           Boolean           @default(true)
  imagem          String?
  cargo           String?
  workspace_id    String
  workspace       Workspace         @relation(fields: [workspace_id], references: [id])
  projetos        Projeto[]
  tarefas         Tarefa[]
  comentarios     Comentario[]
  acoes_historico HistoricoTarefa[]
  dt_insert       DateTime          @default(now())
  dt_update       DateTime          @updatedAt @default(now())

  @@map("usuario")
}

model Coluna {
  id           String          @id @default(uuid())
  nome         String
  cor          String?
  workspace_id String
  workspace    Workspace       @relation(fields: [workspace_id], references: [id])
  projetos     ProjetoColuna[]
  tarefas      Tarefa[]
  dt_insert    DateTime        @default(now())
  dt_update    DateTime        @updatedAt @default(now())

  @@map("coluna")
}

model Projeto {
  id           String          @id @default(uuid())
  nome         String
  descricao    String?         @db.Text
  ativo        Boolean         @default(true)
  workspace_id String
  workspace    Workspace       @relation(fields: [workspace_id], references: [id])
  usuario_id   String
  usuario      Usuario         @relation(fields: [usuario_id], references: [id])
  colunas      ProjetoColuna[]
  tarefas      Tarefa[]
  dt_insert    DateTime        @default(now())
  dt_update    DateTime        @updatedAt @default(now())
  dt_acesso    DateTime        @default(now())
  imagem       String?

  @@map("projeto")
}

model ProjetoColuna {
  projeto_id String
  projeto    Projeto @relation(fields: [projeto_id], references: [id], onDelete: Cascade)
  coluna_id  String
  coluna     Coluna  @relation(fields: [coluna_id], references: [id], onDelete: Cascade)
  ordem      Int

  @@id([projeto_id, coluna_id])
  @@map("projeto_coluna")
}

enum Recorrencia {
  NAO
  DIARIAMENTE
  SEMANALMENTE
  MENSALMENTE
}

model Tarefa {
  id             String           @id @default(cuid())
  titulo         String
  descricao      String?
  concluida      Boolean          @default(false)
  dt_vencimento  DateTime?
  dt_conclusao   DateTime?
  dt_insert      DateTime         @default(now())
  dt_update      DateTime         @updatedAt @default(now())
  prioridade_id  Int
  prioridade     OpcaoPrioridade  @relation(fields: [prioridade_id], references: [id])
  dificuldade_id Int
  dificuldade    OpcaoDificuldade @relation(fields: [dificuldade_id], references: [id])
  projeto_id     String
  projeto        Projeto          @relation(fields: [projeto_id], references: [id], onDelete: Cascade)
  coluna_id      String?
  coluna         Coluna?          @relation(fields: [coluna_id], references: [id])
  usuario_id     String?
  usuario        Usuario?         @relation(fields: [usuario_id], references: [id])
  comentarios    Comentario[]
  historico      HistoricoTarefa[]
  recorrencia    Recorrencia      @default(NAO)
  anexos         Anexo[]

  @@map("tarefa")
}

model OpcaoPrioridade {
  id      Int      @id
  nome    String
  tarefas Tarefa[]

  @@map("opcao_prioridade")
}

model OpcaoDificuldade {
  id      Int      @id
  nome    String
  tarefas Tarefa[]

  @@map("opcao_dificuldade")
}

model Comentario {
  id         String   @id @default(uuid())
  texto      String   @db.Text
  tarefa_id  String
  tarefa     Tarefa   @relation(fields: [tarefa_id], references: [id], onDelete: Cascade)
  usuario_id String
  usuario    Usuario  @relation(fields: [usuario_id], references: [id])
  dt_insert  DateTime @default(now())
  dt_update  DateTime @updatedAt @default(now())

  @@map("comentario")
}

enum CampoAlterado {
  CRIACAO
  TITULO
  DESCRICAO
  DT_VENCIMENTO
  PRIORIDADE
  DIFICULDADE
  COLUNA
  CONCLUSAO
  REABERTURA
  RESPONSAVEL
  ANEXO_REMOVIDO
}

model HistoricoTarefa {
  id           String        @id @default(uuid())
  tarefa_id    String
  tarefa       Tarefa        @relation(fields: [tarefa_id], references: [id], onDelete: Cascade)
  usuario_id   String?
  usuario      Usuario?      @relation(fields: [usuario_id], references: [id])
  campo        CampoAlterado
  valor_antigo String?
  valor_novo   String?
  dt_evento    DateTime      @default(now())

  @@index([tarefa_id])
  @@index([dt_evento])
  @@map("historico_tarefa")
}

model Anexo {
  id        String   @id @default(uuid())
  nome      String
  url       String
  key       String
  tamanho   Int
  dt_upload DateTime @default(now())
  tarefa_id String
  tarefa    Tarefa   @relation(fields: [tarefa_id], references: [id], onDelete: Cascade)

  @@map("anexo")
}