generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String    @id @default(uuid())
  nome      String
  dt_insert DateTime  @default(now())
  dt_update DateTime  @updatedAt
  projetos  Projeto[]
  usuarios  Usuario[]
}

model Usuario {
  id           String       @id @default(uuid())
  nome         String
  email        String       @unique
  workspace_id String
  workspace    Workspace    @relation(fields: [workspace_id], references: [id])
  tarefas      Tarefa[]     // Tarefas que ele é responsável
  comentarios  Comentario[] // Comentários que ele fez
  dt_insert    DateTime     @default(now())
}

model Projeto {
  id           String    @id @default(uuid())
  nome         String
  descricao    String?   @db.Text
  workspace_id String
  workspace    Workspace @relation(fields: [workspace_id], references: [id])
  tarefas      Tarefa[]
  dt_insert    DateTime  @default(now())
  dt_update    DateTime  @updatedAt
}

model Tarefa {
  id             String    @id @default(uuid())
  titulo         String
  descricao      String?   @db.Text // Descrição longa
  prioridade     String    @default("MEDIA") // BAIXA, MEDIA, ALTA
  status         String    @default("PENDENTE") // PENDENTE, FAZENDO, FEITO
  
  // Controle de Datas para SPRINT e CALENDÁRIO
  dt_inicio      DateTime? // Quando a tarefa deve começar
  dt_vencimento  DateTime? // Prazo final (Deadline)
  dt_conclusao   DateTime? // Quando foi de fato terminada
  
  // Recorrência (Ex: 'DIARIO', 'SEMANAL', 'MENSAL')
  recorrencia    String?   

  projeto_id     String
  projeto        Projeto   @relation(fields: [projeto_id], references: [id], onDelete: Cascade)
  
  usuario_id     String?   // Responsável pela tarefa
  usuario        Usuario?  @relation(fields: [usuario_id], references: [id])

  comentarios    Comentario[]

  dt_insert      DateTime  @default(now())
  dt_update      DateTime  @updatedAt
}

model Comentario {
  id          String   @id @default(uuid())
  texto       String   @db.Text
  
  tarefa_id   String
  tarefa      Tarefa   @relation(fields: [tarefa_id], references: [id], onDelete: Cascade)
  
  usuario_id  String
  usuario     Usuario  @relation(fields: [usuario_id], references: [id])

  dt_insert   DateTime @default(now())
}